{
    "geode": "5.6.1",
    "gd": {
        "android": "2.2081"
    },
    "id": "dexname.recordmod",
    "name": "Options Bot",
    "version": "1.1.0",
    "developer": "Dexname",
    "description": "Auto-places Option & Pickup Triggers on jump input in editor",
    "platforms": ["android64"],
    "settings": {
        "enabled": {
            "name": "Enable Recordbot",
            "description": "Вмикає/вимикає автоматичне розміщення тригерів",
            "type": "bool",
            "default": false
        },
        "pickup-item-id": {
            "name": "Pickup Item ID",
            "type": "int",
            "default": 9,
            "min": 1,
            "max": 9999
        },
        "pickup-count-press": {
            "name": "Pickup Count (Press)",
            "description": "Count для Pickup тригера при натисканні",
            "type": "int",
            "default": 5,
            "min": -9999,
            "max": 9999
        },
        "pickup-count-release": {
            "name": "Pickup Count (Release)",
            "description": "Count для Pickup тригера при відпусканні",
            "type": "int",
            "default": -5,
            "min": -9999,
            "max": 9999
        }
    
}
